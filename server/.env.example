# MongoDB Atlas Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/taskflow-pro?retryWrites=true&w=majority

# JWT Secrets (generate strong random strings for production)
JWT_ACCESS_SECRET=your-super-secret-access-token-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-token-key-change-in-production

# Token Expiration
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Server Configuration
PORT=5000
NODE_ENV=production

# Frontend URL (for CORS) - Replace with your Vercel URL
FRONTEND_URL=https://your-frontend.vercel.app

# Cookie settings (set to true for production with HTTPS)
COOKIE_SECURE=true
